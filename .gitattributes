# Always use LF for shell scripts — CRLF breaks bash on Linux/Pi
*.sh text eol=lf

# Python and web files — LF
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Service files — LF
*.service text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.so binary
